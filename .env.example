# General
APP_ENV=development
APP_NAME=agentic-cli-toolkit

# Storage
RESOURCE_DB_PATH=resources.json

# Search tuning (CPU/RAM conscious defaults)
SEARCH_MAX_RESULTS=10
SEARCH_MAX_TOKENS_PER_RESOURCE=256
SEARCH_MIN_TOKEN_LENGTH=3

# Onboarding
ONBOARDING_GUIDE_PATH=AGENT_ONBOARDING.md

# Orchestrator (Clean Architecture CLI)
ORCH_OLLAMA_URL=http://localhost:11434/api/generate
ORCH_OLLAMA_MODEL=llama3.2:3b
ORCH_RESEARCH_DIR=research
ORCH_ONBOARDING_DOC=research/AGENT_ONBOARDING.md

# Optional GitHub publish infrastructure
ORCH_GITHUB_TOKEN=
ORCH_GITHUB_OWNER=
ORCH_GITHUB_REPO=
ORCH_GITHUB_BRANCH=main
